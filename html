<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>Oiled Coffee | Artisan Menu & Digital Payment</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #0c0b0a;
      font-family: 'Space Grotesk', sans-serif;
      color: #f2eee9;
      scroll-behavior: smooth;
    }

    /* premium grain texture overlay */
    body::before {
      content: "";
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-image: radial-gradient(rgba(210, 180, 140, 0.03) 1px, transparent 1px);
      background-size: 28px 28px;
      pointer-events: none;
      z-index: 0;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 24px 28px 60px;
      position: relative;
      z-index: 2;
    }

    /* header with oiled coffee vibe */
    .hero-oil {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      flex-wrap: wrap;
      border-bottom: 2px solid #d9b48b30;
      padding-bottom: 20px;
      margin-bottom: 48px;
    }

    .logo-area h1 {
      font-size: 3.4rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      background: linear-gradient(125deg, #f3cd9b, #c28442, #e7b06e);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      text-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }

    .logo-area p {
      color: #c2a071;
      font-weight: 500;
      font-size: 0.85rem;
      letter-spacing: 1px;
    }

    .tagline-badge {
      background: #1f1b16;
      padding: 8px 18px;
      border-radius: 60px;
      font-size: 0.8rem;
      border: 1px solid #d9a06650;
      backdrop-filter: blur(4px);
    }

    /* layout grid */
    .menu-payment-double {
      display: flex;
      flex-wrap: wrap;
      gap: 32px;
    }

    /* menu panel */
    .menu-panel {
      flex: 2.2;
      background: #141110e0;
      backdrop-filter: blur(2px);
      border-radius: 38px;
      padding: 28px 24px;
      border: 1px solid #2f2a24;
      box-shadow: 0 25px 40px -18px black;
    }

    .category-slider {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 32px;
      border-bottom: 1px solid #2f2a24;
      padding-bottom: 18px;
    }

    .cat-oil {
      background: transparent;
      border: 1px solid #4a3e32;
      color: #e2cfb5;
      padding: 8px 22px;
      border-radius: 60px;
      font-weight: 600;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all 0.2s;
      font-family: inherit;
    }

    .cat-oil.active-oil {
      background: #d9a066;
      border-color: #d9a066;
      color: #0c0b0a;
      box-shadow: 0 0 8px #e2a46e;
    }

    .cat-oil:hover:not(.active-oil) {
      background: #2f281f;
      border-color: #b87a42;
    }

    .menu-category-oil {
      display: none;
      animation: fadeSlide 0.25s ease;
    }

    .menu-category-oil.active-cat-oil {
      display: block;
    }

    @keyframes fadeSlide {
      from { opacity: 0; transform: translateY(8px);}
      to { opacity: 1; transform: translateY(0);}
    }

    .menu-item-oil {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      padding: 16px 0;
      border-bottom: 1px solid #2e2822;
      gap: 12px;
    }

    .item-desc {
      flex: 3;
    }

    .item-desc h4 {
      font-weight: 700;
      font-size: 1.12rem;
      letter-spacing: -0.2px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: baseline;
    }

    .ingredients-light {
      font-size: 0.7rem;
      color: #b8a68c;
      margin-top: 6px;
      line-height: 1.35;
      max-width: 95%;
    }

    .price-oil {
      background: #23201c;
      padding: 5px 16px;
      border-radius: 40px;
      font-weight: 700;
      color: #f0c68a;
      font-size: 1rem;
    }

    .add-oil-btn {
      background: #d9a06630;
      border: 1px solid #d9a066;
      color: #f0cd9b;
      padding: 6px 18px;
      border-radius: 34px;
      font-weight: 600;
      font-size: 0.75rem;
      cursor: pointer;
      transition: 0.2s;
    }

    .add-oil-btn:hover {
      background: #d9a066;
      color: #0c0b0a;
      transform: scale(0.96);
    }

    /* payment card premium */
    .payment-card {
      flex: 1.2;
      min-width: 330px;
      background: #12100e;
      border-radius: 38px;
      padding: 28px 24px;
      border: 1px solid #3f352c;
      backdrop-filter: blur(4px);
      align-self: start;
      position: sticky;
      top: 20px;
      box-shadow: 0 20px 30px -12px rgba(0,0,0,0.5);
    }

    .cart-header-oil {
      font-size: 1.8rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
      border-bottom: 2px solid #d9a06640;
      padding-bottom: 16px;
      margin-bottom: 24px;
    }

    .cart-items-list {
      max-height: 340px;
      overflow-y: auto;
      margin-bottom: 24px;
    }

    .cart-item-row {
      background: #1e1b18;
      margin-bottom: 12px;
      padding: 10px 14px;
      border-radius: 28px;
      display: flex;
      justify-content: space-between;
      font-size: 0.85rem;
    }

    .cart-total-oil {
      display: flex;
      justify-content: space-between;
      font-size: 1.5rem;
      font-weight: 800;
      border-top: 2px solid #2f2a24;
      padding-top: 18px;
      margin: 20px 0;
    }

    .bank-demo-card {
      background: linear-gradient(135deg, #1f2c28, #0f1916);
      border-radius: 28px;
      padding: 20px;
      margin: 20px 0;
      border: 1px solid #d9a06670;
    }

    .demo-bank-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      opacity: 0.7;
    }

    .card-number-demo {
      font-family: monospace;
      font-size: 1.3rem;
      letter-spacing: 2px;
      font-weight: 600;
      margin: 10px 0;
    }

    .pay-demo-btn {
      width: 100%;
      background: #d9a066;
      border: none;
      padding: 14px;
      font-weight: 700;
      font-size: 1rem;
      border-radius: 60px;
      color: #0f0e0c;
      cursor: pointer;
      transition: 0.2s;
      margin-top: 12px;
      font-family: inherit;
    }

    .reset-demo-btn {
      background: #2f2a24;
      color: #e7c9a6;
      margin-top: 10px;
    }

    .status-message {
      background: #1e1915;
      margin-top: 16px;
      padding: 12px;
      border-radius: 60px;
      text-align: center;
      font-size: 0.75rem;
    }

    .free-assets {
      display: flex;
      justify-content: center;
      gap: 18px;
      margin-top: 24px;
      font-size: 0.7rem;
      color: #a58562;
    }

    @media (max-width: 780px) {
      .container {
        padding: 16px;
      }
      .payment-card {
