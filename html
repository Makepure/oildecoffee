<script>
  // OILED COFFEE CART LOGIC
  let oilCart = [];

  function updateOilCartUI() {
    const container = document.getElementById('cartOilList');
    const totalSpan = document.getElementById('cartOilTotal');
    if (oilCart.length === 0) {
      container.innerHTML = '<div style="text-align:center; color:#b28b60;">No drops yet — add fuel ⛽</div>';
      totalSpan.innerText = '0 EGP';
      return;
    }
    const grouped = new Map();
    for (let item of oilCart) {
      if (grouped.has(item.name)) {
        grouped.get(item.name).qty += 1;
      } else {
        grouped.set(item.name, { name: item.name, price: item.price, qty: 1 });
      }
    }
    let total = 0;
    let html = '';
    for (let [_, group] of grouped.entries()) {
      const subtotal = group.price * group.qty;
      total += subtotal;
      html += `<div class="cart-item-row"><span><strong>${group.qty}x</strong> ${group.name}</span><span>${subtotal} EGP</span></div>`;
    }
    container.innerHTML = html;
    totalSpan.innerText = `${total} EGP`;
  }

  function addToOilCart(name, price) {
    oilCart.push({ name, price });
    updateOilCartUI();
    const statusDiv = document.getElementById('paymentOilStatus');
    statusDiv.innerHTML = `✅ added "${name}" — total ${oilCart.reduce((s,i)=>s+i.price,0)} EGP`;
    setTimeout(() => {
      if (statusDiv.innerHTML.includes('added')) statusDiv.innerHTML = '☕ ready • demo card active';
    }, 1800);
  }

  function resetOilCartFunc() {
    oilCart = [];
    updateOilCartUI();
    document.getElementById('paymentOilStatus').innerHTML = '🧽 Cart cleared. Select new items!';
    setTimeout(() => {
      if(document.getElementById('paymentOilStatus').innerHTML.includes('cleared'))
        document.getElementById('paymentOilStatus').innerHTML = '☕ ready • demo card active';
    }, 2000);
  }

  function processOilPayment() {
    const total = oilCart.reduce((sum,i)=>sum+i.price,0);
    if (total === 0) {
      document.getElementById('paymentOilStatus').innerHTML = '⚠️ Cart empty — add some fuel first.';
      return;
    }
    const statusDiv = document.getElementById('paymentOilStatus');
    statusDiv.innerHTML = '🔄 processing bank transaction (demo) ...';
    setTimeout(() => {
      statusDiv.innerHTML = `✅ PAYMENT APPROVED! ${total} EGP charged to demo card 4242. Thank you, Oiled Coffee ♨️`;
      oilCart = [];
      updateOilCartUI();
      setTimeout(() => {
        if(statusDiv.innerHTML.includes('APPROVED')) statusDiv.innerHTML = '✨ order confirmed — enjoy your feast!';
      }, 3500);
    }, 1000);
  }

  // attach listeners for add buttons
  function attachOilAddEvents() {
    document.querySelectorAll('.add-oil-btn').forEach(btn => {
      btn.removeEventListener('click', oilAddHandler);
      btn.addEventListener('click', oilAddHandler);
    });
  }

  function oilAddHandler(e) {
    const menuDiv = e.target.closest('.menu-item-oil');
    if (!menuDiv) return;
    const nameElem = menuDiv.querySelector('h4');
    const name = nameElem ? nameElem.innerText.trim() : "Wild Dish";
    const priceElem = menuDiv.querySelector('.price-oil');
    let price = 0;
    if (priceElem) price = parseInt(priceElem.innerText);
    if (!isNaN(price)) addToOilCart(name, price);
    else addToOilCart(name, 0);
  }

  // TABS (oiled version)
  function initOilTabs() {
    const btns = document.querySelectorAll('.cat-oil');
    const cats = {
      sandwichesOil: document.getElementById('sandwichesOil'),
      chickensOil: document.getElementById('chickensOil'),
      snacksOil: document.getElementById('snacksOil'),
      breakfastOil: document.getElementById('breakfastOil')
    };
    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-catoil');
        btns.forEach(b => b.classList.remove('active-oil'));
        btn.classList.add('active-oil');
        Object.values(cats).forEach(c => c.classList.remove('active-cat-oil'));
        if (target && cats[target]) cats[target].classList.add('active-cat-oil');
      });
    });
  }

  document.getElementById('payOilBtn')?.addEventListener('click', processOilPayment);
  document.getElementById('resetOilCart')?.addEventListener('click', resetOilCartFunc);
  initOilTabs();
  attachOilAddEvents();
  // dynamic observer for future items
  const observer = new MutationObserver(() => attachOilAddEvents());
  observer.observe(document.querySelector('.menu-panel'), { childList: true, subtree: true });
</script>
</body>
</html>
